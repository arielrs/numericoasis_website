---
import { Image } from 'astro:assets';
import { SITE, NAV_LINKS } from '../consts';
import logoRound from '../assets/logos/company-round.jpg';

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header class="sticky top-0 z-50 border-b border-sand-200/60 bg-white/85 backdrop-blur-lg">
  <nav class="container-wide flex h-16 items-center justify-between" aria-label="Main">
    <a href="/" class="group flex items-center gap-2.5" aria-label={`${SITE.name} home`}>
      <Image
        src={logoRound}
        alt=""
        width={36}
        height={36}
        class="h-9 w-9 rounded-xl shadow-[var(--shadow-soft)] ring-1 ring-sand-200/60"
        loading="eager"
      />
      <span class="font-display text-base font-semibold tracking-tight text-brand-900">
        Numeric<span class="text-sun-500">·</span>Oasis
      </span>
    </a>

    <div class="hidden items-center gap-1 md:flex">
      {NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class:list={[
            'rounded-full px-3 py-2 text-sm font-medium transition',
            isActive(link.href)
              ? 'bg-sand-100 text-brand-900'
              : 'text-brand-700 hover:bg-sand-50 hover:text-brand-900',
          ]}
          aria-current={isActive(link.href) ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
    </div>

    <a href="/contact/" class="hidden md:inline-flex btn-cta !py-2 !px-4">
      Start a project
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
    </a>

    <button
      type="button"
      id="nav-toggle"
      class="inline-flex h-10 w-10 items-center justify-center rounded-lg text-brand-700 hover:bg-sand-100 md:hidden"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-sand-200 bg-white md:hidden">
    <div class="container-wide flex flex-col py-3">
      {NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class:list={[
            'rounded-lg px-3 py-2.5 text-sm font-medium transition',
            isActive(link.href)
              ? 'bg-sand-100 text-brand-900'
              : 'text-brand-700 hover:bg-sand-50',
          ]}
        >
          {link.label}
        </a>
      ))}
      <a href="/contact/" class="mt-2 btn-cta justify-center">Start a project</a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(open));
  });
</script>
