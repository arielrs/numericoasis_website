---
import { SITE } from '../consts';
const year = new Date().getFullYear();
---

<footer class="border-t border-slate-200 bg-slate-50">
  <div class="container-wide py-14">
    <div class="grid gap-10 md:grid-cols-4">
      <div class="md:col-span-2">
        <div class="flex items-center gap-2.5">
          <span class="flex h-9 w-9 items-center justify-center rounded-xl bg-gradient-to-br from-brand-900 to-brand-700 font-display text-base font-bold text-white">N</span>
          <span class="font-display text-base font-semibold tracking-tight">Numeric·Oasis</span>
        </div>
        <p class="mt-4 max-w-sm text-sm leading-relaxed text-slate-600">
          {SITE.description}
        </p>
      </div>

      <div>
        <h3 class="font-display text-sm font-semibold text-slate-900">Company</h3>
        <ul class="mt-4 space-y-2 text-sm">
          <li><a class="text-slate-600 hover:text-slate-900" href="/about/">About</a></li>
          <li><a class="text-slate-600 hover:text-slate-900" href="/services/">Services</a></li>
          <li><a class="text-slate-600 hover:text-slate-900" href="/apps/">Apps</a></li>
          <li><a class="text-slate-600 hover:text-slate-900" href="/blog/">Blog</a></li>
          <li><a class="text-slate-600 hover:text-slate-900" href="/contact/">Contact</a></li>
        </ul>
      </div>

      <div>
        <h3 class="font-display text-sm font-semibold text-slate-900">Connect</h3>
        <ul class="mt-4 space-y-2 text-sm">
          <li>
            <a class="text-slate-600 hover:text-slate-900" href={`mailto:${SITE.email}`}>{SITE.email}</a>
          </li>
          <li>
            <a class="text-slate-600 hover:text-slate-900" href={SITE.marketplaceUrl} rel="noopener" target="_blank">Atlassian Marketplace</a>
          </li>
          {SITE.linkedin && (
            <li>
              <a class="text-slate-600 hover:text-slate-900" href={SITE.linkedin} rel="noopener" target="_blank">LinkedIn</a>
            </li>
          )}
          <li>
            <a class="text-slate-600 hover:text-slate-900" href="/rss.xml">RSS feed</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-start justify-between gap-3 border-t border-slate-200 pt-6 text-xs text-slate-500 md:flex-row md:items-center">
      <p>&copy; {year} {SITE.name}. {SITE.location}.</p>
      <p class="font-mono">
        Built with Astro · Hosted on GitHub Pages
      </p>
    </div>
  </div>
</footer>
