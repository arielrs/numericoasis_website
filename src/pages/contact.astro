---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../consts';
---

<BaseLayout
  title="Contact"
  description={`Get in touch with Numeric Oasis. We reply within one working day. ${SITE.email}`}
>
  <section class="bg-gradient-to-b from-slate-50 to-white py-20 sm:py-28">
    <div class="container-wide">
      <p class="eyebrow">Contact</p>
      <h1 class="mt-3 max-w-4xl font-display text-4xl font-bold leading-tight tracking-tight text-slate-900 sm:text-5xl md:text-6xl">
        Tell us what you're building.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-600">
        We reply within one working day. If we're not the right fit, we'll say so — and where we can, point you to someone who is.
      </p>
    </div>
  </section>

  <section class="py-12 sm:py-20">
    <div class="container-wide grid gap-10 md:grid-cols-5">
      <div class="md:col-span-2">
        <h2 class="font-display text-xl font-semibold text-slate-900">Direct contact</h2>
        <ul class="mt-5 space-y-4 text-sm">
          <li>
            <p class="text-slate-500">Email</p>
            <a class="font-medium text-slate-900 hover:text-accent-600" href={`mailto:${SITE.email}`}>{SITE.email}</a>
          </li>
          <li>
            <p class="text-slate-500">Marketplace</p>
            <a class="font-medium text-slate-900 hover:text-accent-600" href={SITE.marketplaceUrl} rel="noopener" target="_blank">View our apps →</a>
          </li>
          {SITE.linkedin && (
            <li>
              <p class="text-slate-500">LinkedIn</p>
              <a class="font-medium text-slate-900 hover:text-accent-600" href={SITE.linkedin} rel="noopener" target="_blank">@numericoasis →</a>
            </li>
          )}
          <li>
            <p class="text-slate-500">Location</p>
            <p class="font-medium text-slate-900">{SITE.location}</p>
          </li>
        </ul>
      </div>

      <div class="md:col-span-3">
        <form
          action={`mailto:${SITE.email}`}
          method="post"
          enctype="text/plain"
          class="rounded-3xl border border-slate-200 bg-white p-8 shadow-[var(--shadow-soft)]"
        >
          <h2 class="font-display text-xl font-semibold text-slate-900">Send us a note</h2>
          <p class="mt-1 text-sm text-slate-500">
            Submitting opens your mail client. Prefer a form-handler? <a class="text-accent-700 underline underline-offset-4" href={`mailto:${SITE.email}`}>Just email us instead.</a>
          </p>

          <div class="mt-6 grid gap-4">
            <label class="grid gap-1.5 text-sm font-medium text-slate-800">
              Your name
              <input type="text" name="name" required class="rounded-lg border border-slate-200 px-3 py-2.5 text-sm text-slate-900 outline-none transition focus:border-accent-500 focus:ring-2 focus:ring-accent-500/30" />
            </label>
            <label class="grid gap-1.5 text-sm font-medium text-slate-800">
              Email
              <input type="email" name="email" required class="rounded-lg border border-slate-200 px-3 py-2.5 text-sm text-slate-900 outline-none transition focus:border-accent-500 focus:ring-2 focus:ring-accent-500/30" />
            </label>
            <label class="grid gap-1.5 text-sm font-medium text-slate-800">
              Company (optional)
              <input type="text" name="company" class="rounded-lg border border-slate-200 px-3 py-2.5 text-sm text-slate-900 outline-none transition focus:border-accent-500 focus:ring-2 focus:ring-accent-500/30" />
            </label>
            <label class="grid gap-1.5 text-sm font-medium text-slate-800">
              What can we help with?
              <textarea name="message" rows="5" required class="rounded-lg border border-slate-200 px-3 py-2.5 text-sm text-slate-900 outline-none transition focus:border-accent-500 focus:ring-2 focus:ring-accent-500/30"></textarea>
            </label>
            <button type="submit" class="btn-primary mt-2 w-full justify-center">Send →</button>
          </div>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
