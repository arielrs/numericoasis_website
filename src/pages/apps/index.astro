---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { PRODUCT_LABELS } from '../../consts';

const apps = (await getCollection('apps')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout
  title="Apps"
  description="Apps from Numeric Oasis on the Atlassian Marketplace. Built on Forge for Jira and Confluence Cloud."
>
  <section class="bg-gradient-to-b from-slate-50 to-white py-20 sm:py-28">
    <div class="container-wide">
      <p class="eyebrow">Marketplace</p>
      <h1 class="mt-3 max-w-4xl font-display text-4xl font-bold leading-tight tracking-tight text-slate-900 sm:text-5xl md:text-6xl">
        Our apps on the Atlassian Marketplace.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-600">
        Each app is built on Forge, Atlassian's Cloud native platform. That means data stays in your tenancy, deployment is simple, and updates ship fast.
      </p>
    </div>
  </section>

  <section class="py-12 sm:py-20">
    <div class="container-wide grid gap-6 md:grid-cols-2">
      {apps.map((app) => (
        <a
          href={`/apps/${app.id}/`}
          class="group flex flex-col justify-between rounded-2xl border border-sand-200 bg-white p-8 transition hover:-translate-y-0.5 hover:border-water-400 hover:shadow-[var(--shadow-soft)]"
        >
          <div>
            <div class="flex items-center gap-4">
              {app.data.icon ? (
                <Image
                  src={app.data.icon}
                  alt={`${app.data.name} logo`}
                  width={64}
                  height={64}
                  class="h-16 w-16 shrink-0 rounded-2xl object-cover ring-1 ring-sand-200"
                />
              ) : (
                <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-brand-900 to-brand-700 font-display text-lg font-bold text-white">
                  {app.data.name.charAt(0)}
                </div>
              )}
              <div>
                <h2 class="font-display text-xl font-semibold text-brand-900 group-hover:text-brand-700">
                  {app.data.name}
                </h2>
                <p class="mt-1 text-sm font-medium text-slate-700">{app.data.tagline}</p>
              </div>
            </div>

            <p class="mt-5 text-base leading-relaxed text-slate-600">{app.data.description}</p>

            {app.data.audiences.length > 0 && (
              <p class="mt-4 text-xs leading-relaxed text-slate-500">
                <span class="font-semibold text-brand-800">Built for:</span> {app.data.audiences.join(' · ')}
              </p>
            )}
          </div>

          <div class="mt-6 flex flex-wrap items-center gap-2 text-xs font-semibold">
            {app.data.products.map((p) => (
              <span class="rounded-full bg-water-50 px-2.5 py-1 text-water-700">{PRODUCT_LABELS[p] ?? p}</span>
            ))}
            {app.data.pricing && /^free$/i.test(app.data.pricing) && (
              <span class="rounded-full bg-sun-50 px-2.5 py-1 text-sun-700">Free</span>
            )}
            <span class="ml-auto text-slate-400 transition group-hover:text-water-600">Read more →</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
