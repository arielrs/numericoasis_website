---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE, PRODUCT_LABELS } from '../../consts';

export async function getStaticPaths() {
  const apps = await getCollection('apps');
  return apps.map((app) => ({
    params: { slug: app.id },
    props: { app },
  }));
}

const { app } = Astro.props;

const softwareJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: app.data.name,
  description: app.data.description,
  applicationCategory: 'BusinessApplication',
  applicationSubCategory: 'AtlassianMarketplaceApp',
  operatingSystem: 'Atlassian Cloud',
  url: `${SITE.url}/apps/${app.id}/`,
  ...(app.data.marketplaceUrl && { downloadUrl: app.data.marketplaceUrl }),
  ...(app.data.marketplaceUrl && { installUrl: app.data.marketplaceUrl }),
  ...(app.data.keyFeatures.length > 0 && {
    featureList: app.data.keyFeatures.join('\n'),
  }),
  ...(app.data.audiences.length > 0 && {
    audience: app.data.audiences.map((a) => ({
      '@type': 'Audience',
      audienceType: a,
    })),
  }),
  ...(app.data.pricing && {
    offers: {
      '@type': 'Offer',
      ...(/^free$/i.test(app.data.pricing)
        ? { price: '0', priceCurrency: 'USD' }
        : { description: app.data.pricing }),
    },
  }),
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
    logo: `${SITE.url}/logo.jpg`,
  },
};

const isFree = !!app.data.pricing && /^free$/i.test(app.data.pricing);
---

<BaseLayout title={app.data.name} description={app.data.description}>
  <script type="application/ld+json" set:html={JSON.stringify(softwareJsonLd)} />

  <!-- HERO -->
  <section class="relative overflow-hidden bg-gradient-to-b from-sand-50 via-white to-white">
    <div class="absolute inset-0 -z-10 opacity-50" aria-hidden="true">
      <div class="absolute -left-24 top-0 h-[460px] w-[460px] rounded-full bg-water-300/40 blur-3xl"></div>
      <div class="absolute right-0 top-32 h-[400px] w-[400px] rounded-full bg-sun-300/30 blur-3xl"></div>
    </div>

    <div class="container-wide pt-12 pb-16 sm:pt-16 sm:pb-20">
      <a href="/apps/" class="text-sm font-medium text-slate-500 hover:text-brand-900">← All apps</a>

      <div class="mt-8 grid gap-10 lg:grid-cols-[auto_1fr] lg:items-start lg:gap-14">
        {app.data.icon && (
          <Image
            src={app.data.icon}
            alt={`${app.data.name} logo`}
            width={140}
            height={140}
            class="h-28 w-28 shrink-0 rounded-3xl object-cover ring-1 ring-sand-200 shadow-[var(--shadow-soft)] sm:h-32 sm:w-32"
            loading="eager"
          />
        )}
        <div>
          <p class="eyebrow">Atlassian Marketplace app</p>
          <h1 class="mt-3 font-display text-4xl font-bold leading-tight tracking-tight text-brand-900 sm:text-5xl md:text-6xl">
            {app.data.name}
          </h1>
          <p class="mt-5 max-w-2xl text-xl leading-relaxed text-slate-700 sm:text-2xl">
            {app.data.tagline}
          </p>

          <div class="mt-7 flex flex-wrap items-center gap-2">
            {app.data.products.map((p) => (
              <span class="rounded-full bg-brand-50 px-3 py-1 text-xs font-semibold text-brand-700">
                For {PRODUCT_LABELS[p] ?? p}
              </span>
            ))}
            {isFree ? (
              <span class="rounded-full bg-water-100 px-3 py-1 text-xs font-semibold text-water-700">
                Free
              </span>
            ) : app.data.pricing ? (
              <span class="rounded-full bg-sun-50 px-3 py-1 text-xs font-semibold text-sun-700">
                Paid, see Marketplace
              </span>
            ) : null}
          </div>

          <div class="mt-9 flex flex-wrap items-center gap-3">
            {app.data.marketplaceUrl && (
              <a href={app.data.marketplaceUrl} class="btn-cta" rel="noopener" target="_blank">
                Install on Atlassian Marketplace
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7M7 7h10v10"/></svg>
              </a>
            )}
            <a href="/contact/" class="btn-secondary">Talk to the team</a>
          </div>

          <p class="mt-9 max-w-3xl text-base leading-relaxed text-slate-600">
            {app.data.description}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST SIGNALS -->
  {app.data.trustSignals.length > 0 && (
    <section class="border-y border-sand-200 bg-white py-6">
      <div class="container-wide">
        <ul class="flex flex-wrap items-center justify-center gap-x-6 gap-y-3 text-xs font-semibold uppercase tracking-[0.14em] text-brand-700">
          {app.data.trustSignals.map((t) => (
            <li class="flex items-center gap-2">
              <svg class="text-water-600" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              {t}
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- VALUE PROPS -->
  {app.data.valueProps.length > 0 && (
    <section class="bg-sand-50 py-16 sm:py-24">
      <div class="container-wide">
        <div class="max-w-2xl">
          <p class="eyebrow">Why {app.data.name}</p>
          <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-brand-900 sm:text-4xl">
            What teams actually get out of it.
          </h2>
        </div>
        <div class="mt-12 grid gap-6 md:grid-cols-3">
          {app.data.valueProps.map((vp) => (
            <article class="rounded-2xl border border-sand-200 bg-white p-7 shadow-[var(--shadow-soft)]">
              {vp.icon && <div class="text-3xl" aria-hidden="true">{vp.icon}</div>}
              <h3 class="mt-4 font-display text-xl font-semibold tracking-tight text-brand-900">
                {vp.title}
              </h3>
              <p class="mt-3 text-base leading-relaxed text-slate-600">{vp.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- KEY FEATURES + AUDIENCES -->
  {(app.data.keyFeatures.length > 0 || app.data.audiences.length > 0) && (
    <section class="py-16 sm:py-24">
      <div class="container-wide grid gap-12 md:grid-cols-2">
        {app.data.keyFeatures.length > 0 && (
          <div>
            <p class="eyebrow">Key features</p>
            <h2 class="mt-3 font-display text-2xl font-bold tracking-tight text-brand-900 sm:text-3xl">
              Everything you need, nothing you don&apos;t.
            </h2>
            <ul class="mt-6 flex flex-wrap gap-2">
              {app.data.keyFeatures.map((f) => (
                <li class="rounded-full border border-sand-200 bg-white px-3.5 py-1.5 text-sm font-medium text-brand-800">
                  {f}
                </li>
              ))}
            </ul>
          </div>
        )}
        {app.data.audiences.length > 0 && (
          <div>
            <p class="eyebrow">Built for</p>
            <h2 class="mt-3 font-display text-2xl font-bold tracking-tight text-brand-900 sm:text-3xl">
              The people who get the most value.
            </h2>
            <ul class="mt-6 flex flex-wrap gap-2">
              {app.data.audiences.map((a) => (
                <li class="rounded-full bg-water-50 px-3.5 py-1.5 text-sm font-medium text-water-700">
                  {a}
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </section>
  )}

  <!-- SCREENSHOT GALLERY (only renders if local screenshots exist) -->
  {app.data.screenshots.length > 0 && (
    <section class="bg-sand-50 py-16 sm:py-24">
      <div class="container-wide">
        <div class="max-w-2xl">
          <p class="eyebrow">See it in action</p>
          <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-brand-900 sm:text-4xl">
            {app.data.name} at a glance.
          </h2>
        </div>
        <ul class="mt-12 grid gap-6 md:grid-cols-2">
          {app.data.screenshots.map((shot, i) => (
            <li class:list={[i === 0 && app.data.screenshots.length > 1 ? 'md:col-span-2' : '']}>
              <button
                type="button"
                class="group block w-full overflow-hidden rounded-2xl border border-sand-200 bg-white text-left shadow-[var(--shadow-soft)] transition hover:-translate-y-0.5 hover:shadow-lg focus:outline-2 focus:outline-offset-2 focus:outline-sun-400"
                data-lightbox-trigger
                data-caption={shot.caption}
                data-full={shot.image.src}
                aria-label={`Open screenshot: ${shot.caption}`}
              >
                <div class="relative">
                  <Image
                    src={shot.image}
                    alt={shot.caption}
                    width={1280}
                    height={Math.round((shot.image.height / shot.image.width) * 1280)}
                    class="block w-full"
                    loading="lazy"
                  />
                  <span class="pointer-events-none absolute right-3 top-3 rounded-full bg-brand-900/85 px-3 py-1.5 text-xs font-semibold text-white opacity-0 transition group-hover:opacity-100">
                    Click to enlarge
                  </span>
                </div>
              </button>
              <p class="mt-3 px-1 text-sm leading-relaxed text-slate-600">{shot.caption}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- FINAL CTA -->
  <section class="py-16 sm:py-24">
    <div class="container-wide">
      <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-brand-900 via-brand-800 to-deep-700 p-10 sm:p-16">
        <div class="absolute -right-20 -top-20 h-64 w-64 rounded-full bg-sun-500/30 blur-3xl" aria-hidden="true"></div>
        <div class="absolute -left-10 bottom-0 h-48 w-48 rounded-full bg-water-400/30 blur-3xl" aria-hidden="true"></div>
        <div class="relative max-w-2xl">
          <h2 class="font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">
            Ready to try {app.data.name}?
          </h2>
          <p class="mt-4 text-lg text-brand-100">
            {isFree
              ? `${app.data.name} is free on the Atlassian Marketplace. Install it now and see results in minutes.`
              : `Install ${app.data.name} from the Atlassian Marketplace, or get in touch for a walkthrough or enterprise quote.`}
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            {app.data.marketplaceUrl && (
              <a href={app.data.marketplaceUrl} class="btn-cta" rel="noopener" target="_blank">
                Install on Marketplace
              </a>
            )}
            <a href="/contact/" class="btn-secondary !bg-white">Contact us</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- LIGHTBOX -->
  {app.data.screenshots.length > 0 && (
    <dialog
      id="screenshot-lightbox"
      class="m-auto w-[min(92vw,1400px)] max-w-none rounded-3xl border-0 bg-transparent p-0 backdrop:bg-brand-950/80 backdrop:backdrop-blur-sm"
    >
      <div class="relative">
        <button
          type="button"
          aria-label="Close"
          data-lightbox-close
          class="absolute right-3 top-3 z-10 inline-flex h-10 w-10 items-center justify-center rounded-full bg-brand-900/85 text-white transition hover:bg-brand-800"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
        <img id="lightbox-image" alt="" class="block max-h-[80vh] w-full rounded-3xl object-contain bg-brand-950" />
        <p id="lightbox-caption" class="mt-3 px-2 text-center text-sm text-white/90 drop-shadow"></p>
      </div>
    </dialog>

    <script>
      const dialog = document.getElementById('screenshot-lightbox') as HTMLDialogElement | null;
      const image = document.getElementById('lightbox-image') as HTMLImageElement | null;
      const caption = document.getElementById('lightbox-caption');
      const closeBtn = document.querySelector('[data-lightbox-close]') as HTMLButtonElement | null;

      document.querySelectorAll<HTMLButtonElement>('[data-lightbox-trigger]').forEach((btn) => {
        btn.addEventListener('click', () => {
          if (!dialog || !image) return;
          image.src = btn.dataset.full ?? '';
          image.alt = btn.dataset.caption ?? '';
          if (caption) caption.textContent = btn.dataset.caption ?? '';
          dialog.showModal();
        });
      });

      closeBtn?.addEventListener('click', () => dialog?.close());
      dialog?.addEventListener('click', (e) => {
        if (e.target === dialog) dialog.close();
      });
    </script>
  )}
</BaseLayout>
