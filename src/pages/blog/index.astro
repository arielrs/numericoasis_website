---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const allTags = Array.from(new Set(posts.flatMap((p) => p.data.tags))).sort();
const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout
  title="Blog"
  description="Notes from Numeric Oasis — building Atlassian Forge apps and custom SaaS, with the lessons we collect along the way."
>
  <section class="bg-gradient-to-b from-slate-50 to-white py-20 sm:py-28">
    <div class="container-wide">
      <p class="eyebrow">Writing</p>
      <h1 class="mt-3 max-w-4xl font-display text-4xl font-bold leading-tight tracking-tight text-slate-900 sm:text-5xl md:text-6xl">
        Notes from the workshop.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-600">
        Forge tales, Marketplace go-to-market notes, and the occasional opinion. Subscribe via <a href="/rss.xml" class="text-water-700 underline underline-offset-4">RSS</a>.
      </p>
      {allTags.length > 0 && (
        <div class="mt-8 flex flex-wrap gap-2" data-tag-filters>
          <button type="button" data-tag="" class="rounded-full bg-slate-900 px-3 py-1 text-xs font-semibold text-white">All</button>
          {allTags.map((t) => (
            <button type="button" data-tag={t} class="rounded-full border border-slate-200 bg-white px-3 py-1 text-xs font-semibold text-slate-700 hover:border-slate-300">
              #{t}
            </button>
          ))}
        </div>
      )}
    </div>
  </section>

  <section class="py-12 sm:py-20">
    <div class="container-wide">
      {posts.length === 0 ? (
        <p class="text-center text-slate-500">No posts yet — check back soon.</p>
      ) : (
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3" data-post-grid>
          {posts.map((post) => (
            <a
              href={`/blog/${post.id}/`}
              class="group flex flex-col overflow-hidden rounded-2xl border border-sand-200 bg-white transition hover:-translate-y-0.5 hover:shadow-[var(--shadow-soft)]"
              data-tags={post.data.tags.join(',')}
            >
              {post.data.heroImage && (
                <div class="aspect-[16/10] overflow-hidden bg-sand-100">
                  <Image
                    src={post.data.heroImage}
                    alt=""
                    width={640}
                    height={400}
                    class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="flex flex-1 flex-col p-6">
                <time datetime={post.data.pubDate.toISOString()} class="text-xs font-semibold uppercase tracking-wider text-slate-500">
                  {fmtDate(post.data.pubDate)}
                </time>
                <h2 class="mt-3 font-display text-lg font-semibold text-brand-900 group-hover:text-brand-700">
                  {post.data.title}
                </h2>
                <p class="mt-2 line-clamp-3 text-sm leading-relaxed text-slate-600">
                  {post.data.description}
                </p>
                {post.data.tags.length > 0 && (
                  <div class="mt-4 flex flex-wrap gap-1.5 text-xs font-medium text-slate-500">
                    {post.data.tags.map((t) => (
                      <span>#{t}</span>
                    ))}
                  </div>
                )}
                <span class="mt-auto pt-4 text-xs font-semibold text-water-700">Read post →</span>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <script>
    const filterButtons = document.querySelectorAll('[data-tag-filters] button');
    const cards = document.querySelectorAll('[data-post-grid] a');
    filterButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const target = (btn as HTMLButtonElement).dataset.tag ?? '';
        filterButtons.forEach((b) => {
          b.classList.remove('bg-slate-900', 'text-white');
          b.classList.add('border', 'border-slate-200', 'bg-white', 'text-slate-700');
        });
        btn.classList.add('bg-slate-900', 'text-white');
        btn.classList.remove('border', 'border-slate-200', 'bg-white', 'text-slate-700');
        cards.forEach((card) => {
          const tags = ((card as HTMLAnchorElement).dataset.tags ?? '').split(',');
          const show = !target || tags.includes(target);
          (card as HTMLElement).style.display = show ? '' : 'none';
        });
      });
    });
  </script>
</BaseLayout>
