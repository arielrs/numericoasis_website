---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../consts';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const sorted = [...posts].sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
  );
  return sorted.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      prev: sorted[i + 1] ?? null,
      next: sorted[i - 1] ?? null,
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);

const url = new URL(`/blog/${post.id}/`, SITE.url).toString();
const blogJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: { '@type': 'Person', name: post.data.author },
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    logo: { '@type': 'ImageObject', url: `${SITE.url}/logo.jpg` },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
  url,
  keywords: post.data.tags.join(', '),
};

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const shareText = encodeURIComponent(`${post.data.title} — ${SITE.name}`);
const shareUrl = encodeURIComponent(url);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  article={{
    publishedTime: post.data.pubDate.toISOString(),
    modifiedTime: post.data.updatedDate?.toISOString(),
    author: post.data.author,
    tags: post.data.tags,
  }}
>
  <script type="application/ld+json" set:html={JSON.stringify(blogJsonLd)} />

  <article>
    <header class="bg-gradient-to-b from-slate-50 to-white pt-16 pb-12 sm:pt-24 sm:pb-16">
      <div class="container-prose">
        <a href="/blog/" class="text-sm font-medium text-slate-500 hover:text-slate-900">← All posts</a>
        <p class="eyebrow mt-8">Blog</p>
        <h1 class="mt-3 font-display text-3xl font-bold leading-tight tracking-tight text-slate-900 sm:text-4xl md:text-5xl">
          {post.data.title}
        </h1>
        <p class="mt-5 text-lg text-slate-600">{post.data.description}</p>

        <div class="mt-8 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-slate-500">
          <span class="font-medium text-slate-700">{post.data.author}</span>
          <span aria-hidden="true">·</span>
          <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
          {post.data.updatedDate && (
            <>
              <span aria-hidden="true">·</span>
              <span>Updated {fmt(post.data.updatedDate)}</span>
            </>
          )}
          {post.data.tags.length > 0 && (
            <>
              <span aria-hidden="true">·</span>
              <span class="space-x-2">
                {post.data.tags.map((t) => (
                  <span class="text-water-700">#{t}</span>
                ))}
              </span>
            </>
          )}
        </div>
      </div>
    </header>

    <div class="container-prose prose-custom pb-16">
      <Content />
    </div>

    <div class="container-prose pb-16">
      <div class="rounded-2xl border border-slate-200 bg-paper-soft p-6">
        <p class="text-xs font-semibold uppercase tracking-wider text-slate-500">Share</p>
        <div class="mt-3 flex flex-wrap gap-3 text-sm font-medium">
          <a class="text-slate-700 hover:text-water-700" href={`https://www.linkedin.com/sharing/share-offsite/?url=${shareUrl}`} target="_blank" rel="noopener">LinkedIn</a>
          <a class="text-slate-700 hover:text-water-700" href={`https://twitter.com/intent/tweet?text=${shareText}&url=${shareUrl}`} target="_blank" rel="noopener">X / Twitter</a>
          <a class="text-slate-700 hover:text-water-700" href={`mailto:?subject=${shareText}&body=${shareUrl}`}>Email</a>
        </div>
      </div>
    </div>

    {(prev || next) && (
      <nav class="container-prose grid gap-4 pb-20 sm:grid-cols-2" aria-label="Post navigation">
        {prev ? (
          <a href={`/blog/${prev.id}/`} class="rounded-2xl border border-slate-200 bg-white p-5 transition hover:-translate-y-0.5 hover:shadow-[var(--shadow-soft)]">
            <span class="text-xs font-semibold uppercase tracking-wider text-slate-500">← Previous</span>
            <p class="mt-2 font-display text-base font-semibold text-slate-900">{prev.data.title}</p>
          </a>
        ) : <div></div>}
        {next ? (
          <a href={`/blog/${next.id}/`} class="rounded-2xl border border-slate-200 bg-white p-5 text-right transition hover:-translate-y-0.5 hover:shadow-[var(--shadow-soft)]">
            <span class="text-xs font-semibold uppercase tracking-wider text-slate-500">Next →</span>
            <p class="mt-2 font-display text-base font-semibold text-slate-900">{next.data.title}</p>
          </a>
        ) : <div></div>}
      </nav>
    )}
  </article>
</BaseLayout>
