---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, PRODUCT_LABELS } from '../consts';

const apps = (await getCollection('apps'))
  .filter((a) => a.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---

<BaseLayout title="Software house, Atlassian partner, IT consultancy" description={SITE.description}>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-b from-slate-50 via-white to-white">
    <div class="absolute inset-0 -z-10 opacity-60" aria-hidden="true">
      <div class="absolute -left-32 top-0 h-[480px] w-[480px] rounded-full bg-water-300/40 blur-3xl"></div>
      <div class="absolute right-0 top-32 h-[420px] w-[420px] rounded-full bg-sun-300/30 blur-3xl"></div>
    </div>

    <div class="container-wide pt-20 pb-24 sm:pt-28 sm:pb-32">
      <p class="eyebrow">Software house · Atlassian Marketplace Partner · IT consultancy</p>
      <h1 class="mt-4 max-w-4xl font-display text-4xl font-bold leading-[1.05] tracking-tight text-slate-900 sm:text-5xl md:text-6xl lg:text-7xl">
        Software, services, and<br class="hidden md:block" />
        <span class="bg-gradient-to-r from-brand-700 via-water-500 to-sun-500 bg-clip-text text-transparent">15 years of know-how.</span>
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-600 sm:text-xl">
        We build custom SaaS and Atlassian Forge apps. We consult on business and IT processes. We support the teams that run them. One partner across build, advise, and run.
      </p>
      <div class="mt-10 flex flex-wrap items-center gap-3">
        <a href="/contact/" class="btn-primary">
          Start a project
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <a href="/apps/" class="btn-secondary">Browse our apps</a>
      </div>

      <dl class="mt-16 grid grid-cols-2 gap-8 border-t border-slate-200 pt-10 sm:grid-cols-4">
        {[
          { k: '15 years', v: 'Of building and consulting' },
          { k: '4+ apps', v: 'On the Atlassian Marketplace' },
          { k: 'Atlassian', v: 'Forge Marketplace partner' },
          { k: 'BR · EU · US', v: 'Time zones served' },
        ].map(({ k, v }) => (
          <div>
            <dt class="font-display text-3xl font-bold text-slate-900">{k}</dt>
            <dd class="mt-1 text-sm text-slate-500">{v}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- Services -->
  <section class="border-y border-slate-200 bg-paper-soft py-20 sm:py-28">
    <div class="container-wide">
      <div class="max-w-2xl">
        <p class="eyebrow">What we do</p>
        <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
          Four ways we help teams build, run, and improve their software.
        </h2>
      </div>

      <div class="mt-14 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        {[
          {
            title: 'Custom software & SaaS',
            desc: 'Greenfield SaaS, web and mobile apps, integrations, and bespoke platforms in TypeScript, Node, and React.',
            icon: '🛠️',
          },
          {
            title: 'Atlassian apps & platform',
            desc: 'Forge apps for the Marketplace, custom plugins, migrations, audits, and Jira and Confluence health work.',
            icon: '🧩',
          },
          {
            title: 'Business & IT consulting',
            desc: 'ITIL and ITSM, process design, governance, and the rollouts that turn a strategy into an actually working operation.',
            icon: '🧭',
          },
          {
            title: 'Customer support & managed services',
            desc: 'Long term support, SLAs, and operations for the software we build and the platforms you run on.',
            icon: '🎧',
          },
        ].map((s) => (
          <article class="group rounded-2xl border border-slate-200 bg-white p-7 shadow-[var(--shadow-soft)] transition hover:-translate-y-0.5 hover:border-water-300 hover:shadow-lg">
            <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-gradient-to-br from-brand-50 to-water-300/20 text-xl">
              <span aria-hidden="true">{s.icon}</span>
            </div>
            <h3 class="mt-5 font-display text-lg font-semibold text-slate-900">{s.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600">{s.desc}</p>
          </article>
        ))}
      </div>

      <div class="mt-10">
        <a href="/services/" class="text-sm font-semibold text-water-700 hover:text-water-600">
          See all services →
        </a>
      </div>
    </div>
  </section>

  <!-- Apps -->
  <section class="py-20 sm:py-28">
    <div class="container-wide">
      <div class="flex flex-col items-start justify-between gap-4 md:flex-row md:items-end">
        <div class="max-w-2xl">
          <p class="eyebrow">From the Marketplace</p>
          <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
            Apps trusted by Atlassian teams.
          </h2>
        </div>
        <a href="/apps/" class="text-sm font-semibold text-water-700 hover:text-water-600">
          Browse all apps →
        </a>
      </div>

      <div class="mt-12 grid gap-5 md:grid-cols-2">
        {apps.map((app) => (
          <a
            href={`/apps/${app.id}/`}
            class="group flex flex-col justify-between rounded-2xl border border-sand-200 bg-white p-7 transition hover:-translate-y-0.5 hover:border-water-400 hover:shadow-[var(--shadow-soft)]"
          >
            <div>
              <div class="flex items-center gap-4">
                {app.data.icon ? (
                  <Image
                    src={app.data.icon}
                    alt={`${app.data.name} logo`}
                    width={56}
                    height={56}
                    class="h-14 w-14 shrink-0 rounded-xl object-cover ring-1 ring-sand-200"
                  />
                ) : (
                  <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-brand-900 to-brand-700 font-display text-base font-bold text-white">
                    {app.data.name.charAt(0)}
                  </div>
                )}
                <div>
                  <h3 class="font-display text-xl font-semibold text-brand-900 group-hover:text-brand-700">
                    {app.data.name}
                  </h3>
                  <p class="mt-1 text-sm font-medium text-slate-700">{app.data.tagline}</p>
                </div>
              </div>
              <p class="mt-5 line-clamp-4 text-sm leading-relaxed text-slate-600">
                {app.data.description}
              </p>
              {app.data.audiences.length > 0 && (
                <p class="mt-4 text-xs leading-relaxed text-slate-500">
                  <span class="font-semibold text-brand-800">Built for:</span> {app.data.audiences.join(' · ')}
                </p>
              )}
            </div>
            <div class="mt-6 flex flex-wrap items-center gap-2 text-xs font-semibold">
              {app.data.products.map((p) => (
                <span class="rounded-full bg-water-50 px-2.5 py-1 text-water-700">{PRODUCT_LABELS[p] ?? p}</span>
              ))}
              {app.data.pricing && /^free$/i.test(app.data.pricing) && (
                <span class="rounded-full bg-sun-50 px-2.5 py-1 text-sun-700">Free</span>
              )}
              <span class="ml-auto text-slate-400 transition group-hover:text-water-600">Read more →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Recent posts -->
  {posts.length > 0 && (
    <section class="border-t border-slate-200 bg-paper-soft py-20 sm:py-28">
      <div class="container-wide">
        <div class="flex flex-col items-start justify-between gap-4 md:flex-row md:items-end">
          <div>
            <p class="eyebrow">From the blog</p>
            <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
              Notes from the workshop.
            </h2>
          </div>
          <a href="/blog/" class="text-sm font-semibold text-water-700 hover:text-water-600">
            All posts →
          </a>
        </div>

        <div class="mt-12 grid gap-6 md:grid-cols-3">
          {posts.map((post) => (
            <a
              href={`/blog/${post.id}/`}
              class="group flex flex-col overflow-hidden rounded-2xl border border-sand-200 bg-white transition hover:-translate-y-0.5 hover:shadow-[var(--shadow-soft)]"
            >
              {post.data.heroImage && (
                <div class="aspect-[16/10] overflow-hidden bg-sand-100">
                  <Image
                    src={post.data.heroImage}
                    alt=""
                    width={640}
                    height={400}
                    class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="flex flex-1 flex-col p-6">
                <time datetime={post.data.pubDate.toISOString()} class="text-xs font-semibold uppercase tracking-wider text-slate-500">
                  {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </time>
                <h3 class="mt-3 font-display text-lg font-semibold text-brand-900 group-hover:text-brand-700">
                  {post.data.title}
                </h3>
                <p class="mt-2 line-clamp-3 text-sm leading-relaxed text-slate-600">
                  {post.data.description}
                </p>
                <span class="mt-auto pt-4 text-xs font-semibold text-water-700">Read post →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="py-20 sm:py-28">
    <div class="container-wide">
      <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-brand-900 via-brand-800 to-deep-700 p-10 sm:p-16">
        <div class="absolute -right-20 -top-20 h-64 w-64 rounded-full bg-sun-500/30 blur-3xl" aria-hidden="true"></div>
        <div class="absolute -left-10 bottom-0 h-48 w-48 rounded-full bg-water-400/30 blur-3xl" aria-hidden="true"></div>
        <div class="relative max-w-2xl">
          <h2 class="font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">
            Got something to build, fix, or rethink?
          </h2>
          <p class="mt-4 text-lg text-brand-100">
            Tell us about it. We'll reply within one working day with an honest take and, if we're a fit, a path forward.
          </p>
          <a href="/contact/" class="mt-8 inline-flex btn-primary !bg-white !text-brand-900 hover:!bg-brand-50">
            Start the conversation
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
