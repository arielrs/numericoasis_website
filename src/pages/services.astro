---
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
  {
    title: 'Custom software & SaaS development',
    summary: 'Greenfield SaaS, web and mobile apps, integrations, and bespoke platforms.',
    body: 'When the right tool does not exist yet, we build it. Modern, hosted, fully owned by you, with the integrations to plug into the rest of your stack.',
    bullets: [
      'TypeScript, Node, React, and modern frameworks',
      'Web and mobile applications',
      'OAuth, SSO, and fine grained permissions',
      'Background jobs, queues, and scheduled work',
      'Cloud hosting on AWS, Cloudflare, or Render',
      'Integrations with Atlassian, Slack, GitHub, and beyond',
    ],
    icon: '🛠️',
  },
  {
    title: 'Atlassian apps & platform expertise',
    summary: 'Forge apps for the Marketplace plus deep Jira and Confluence platform work.',
    body: 'We design, build, and ship Forge apps end to end, from a single Jira admin panel to a multi product Marketplace listing. We also clean up, audit, and migrate the platforms that run them.',
    bullets: [
      'Forge apps for Jira, Confluence, JSM, and Bitbucket Cloud',
      'UI Kit and Custom UI surfaces',
      'Forge SQL, KVS, scheduled triggers, and webhooks',
      'Marketplace listing strategy, pricing, and security review prep',
      'Server and Data Center to Cloud migration planning',
      'App rationalization, audits, and performance tuning',
    ],
    icon: '🧩',
  },
  {
    title: 'Business & IT service consulting',
    summary: 'ITIL, ITSM, process design, governance, and the rollouts that make them stick.',
    body: 'Tools alone do not change how a team works. We pair the platform side with deep process and governance work, so your investment lands as actual operational improvement.',
    bullets: [
      'ITIL v4 and ITSM advisory',
      'Process design, mapping, and rollout',
      'Governance, change, and release management',
      'Tooling roadmaps and Marketplace strategy',
      'Service catalog design',
      'Org and team enablement',
    ],
    icon: '🧭',
  },
  {
    title: 'Customer support & managed services',
    summary: 'Long term support, SLAs, and operations for the software and platforms that matter.',
    body: 'Once the build lands, the real work starts. We run tier 1 to tier 3 support, manage releases, and stay close to the teams using what we ship, with SLAs you can plan around.',
    bullets: [
      'Tier 1, 2, and 3 support models',
      'SLA backed operations and on call',
      'Release cadence and patch management',
      'Documentation, runbooks, and training',
      'Long term partnership and retainer arrangements',
      'Continuous improvement loops',
    ],
    icon: '🎧',
  },
];
---

<BaseLayout
  title="Services"
  description="Custom software development, Atlassian apps and platform consulting, business and IT service consulting, and managed support from Numeric Oasis."
>
  <section class="bg-gradient-to-b from-slate-50 to-white py-20 sm:py-28">
    <div class="container-wide">
      <p class="eyebrow">What we do</p>
      <h1 class="mt-3 max-w-4xl font-display text-4xl font-bold leading-tight tracking-tight text-slate-900 sm:text-5xl md:text-6xl">
        Build, advise, and run. Across software, Atlassian, and operations.
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-relaxed text-slate-600">
        Four practices, one team. Fifteen years of experience pairing custom software with the consulting and support that makes it land. Atlassian heavy, but not Atlassian only.
      </p>
    </div>
  </section>

  <section class="py-12 sm:py-20">
    <div class="container-wide grid gap-12">
      {services.map((s, i) => (
        <article class="grid gap-8 rounded-3xl border border-slate-200 bg-white p-8 shadow-[var(--shadow-soft)] sm:p-12 md:grid-cols-3">
          <div class="md:col-span-1">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-brand-50 to-water-300/20 text-2xl">
              <span aria-hidden="true">{s.icon}</span>
            </div>
            <h2 class="mt-5 font-display text-2xl font-bold tracking-tight text-slate-900">{s.title}</h2>
            <p class="mt-3 text-sm text-slate-500">0{i + 1}</p>
          </div>
          <div class="md:col-span-2">
            <p class="font-display text-lg font-medium text-slate-900">{s.summary}</p>
            <p class="mt-4 text-base leading-relaxed text-slate-600">{s.body}</p>
            <ul class="mt-6 grid gap-2 sm:grid-cols-2">
              {s.bullets.map((b) => (
                <li class="flex items-start gap-2 text-sm text-slate-700">
                  <svg class="mt-0.5 shrink-0 text-water-600" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  <span>{b}</span>
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="py-12 sm:py-20">
    <div class="container-wide">
      <div class="rounded-3xl bg-gradient-to-br from-brand-900 to-brand-700 p-10 text-center sm:p-16">
        <h2 class="font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">
          Not sure which fits?
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-brand-100">
          Send us the rough shape of the problem. We'll come back with a recommendation, even if it's "this is not the right scope for us."
        </p>
        <a href="/contact/" class="mt-8 inline-flex btn-primary !bg-white !text-brand-900 hover:!bg-brand-50">
          Talk to us →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
