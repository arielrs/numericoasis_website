---
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
  {
    title: 'Atlassian Forge app development',
    summary: 'Marketplace-ready apps built on the Forge platform.',
    body: 'We design, build, and ship Forge apps end-to-end — from a single Jira admin panel to a multi-product Marketplace listing with paid tiers. Cloud-native, security-reviewed, supported.',
    bullets: [
      'Jira, Confluence, JSM, and Bitbucket Cloud apps',
      'UI Kit and Custom UI surfaces',
      'Forge SQL, KVS, scheduled triggers, and webhooks',
      'Marketplace listing strategy and pricing',
      'Security review preparation',
    ],
    icon: '⚙️',
  },
  {
    title: 'Custom SaaS & integrations',
    summary: 'Bespoke web apps that talk to Atlassian — and the rest of your stack.',
    body: 'When a Marketplace app cannot quite fit, we build the SaaS that does. Modern, hosted, fully owned by you — with the integrations to plug into Jira, Confluence, Slack, GitHub, and beyond.',
    bullets: [
      'Greenfield SaaS in TypeScript / Node / React',
      'Atlassian Connect & Forge hybrid integrations',
      'OAuth, SSO, fine-grained permissions',
      'Background jobs, queues, and scheduled work',
      'Cloud hosting on AWS, Cloudflare, or Render',
    ],
    icon: '🧩',
  },
  {
    title: 'Atlassian platform consulting',
    summary: 'Cleanups, migrations, and architecture reviews.',
    body: 'A senior set of eyes on a Jira instance that is starting to drag — or on a Server-to-Cloud migration that needs to land cleanly. We assess, recommend, and where invited, execute.',
    bullets: [
      'Custom field, scheme, and workflow audits',
      'Server / Data Center to Cloud migration planning',
      'Permission and access reviews',
      'Performance tuning of Jira and Confluence',
      'App rationalization (which Marketplace apps to keep)',
    ],
    icon: '🧭',
  },
];
---

<BaseLayout
  title="Services"
  description="Atlassian Forge app development, custom SaaS, and platform consulting from the team at Numeric Oasis."
>
  <section class="bg-gradient-to-b from-slate-50 to-white py-20 sm:py-28">
    <div class="container-wide">
      <p class="eyebrow">What we do</p>
      <h1 class="mt-3 max-w-4xl font-display text-4xl font-bold leading-tight tracking-tight text-slate-900 sm:text-5xl md:text-6xl">
        Services for teams that take Atlassian seriously.
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-relaxed text-slate-600">
        Three core practices, all built on the same belief: tools that enable your team should be a joy to use, not a tax to pay.
      </p>
    </div>
  </section>

  <section class="py-12 sm:py-20">
    <div class="container-wide grid gap-12">
      {services.map((s, i) => (
        <article class="grid gap-8 rounded-3xl border border-slate-200 bg-white p-8 shadow-[var(--shadow-soft)] sm:p-12 md:grid-cols-3">
          <div class="md:col-span-1">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-brand-50 to-accent-300/20 text-2xl">
              <span aria-hidden="true">{s.icon}</span>
            </div>
            <h2 class="mt-5 font-display text-2xl font-bold tracking-tight text-slate-900">{s.title}</h2>
            <p class="mt-3 text-sm text-slate-500">0{i + 1}</p>
          </div>
          <div class="md:col-span-2">
            <p class="font-display text-lg font-medium text-slate-900">{s.summary}</p>
            <p class="mt-4 text-base leading-relaxed text-slate-600">{s.body}</p>
            <ul class="mt-6 grid gap-2 sm:grid-cols-2">
              {s.bullets.map((b) => (
                <li class="flex items-start gap-2 text-sm text-slate-700">
                  <svg class="mt-0.5 shrink-0 text-accent-600" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  <span>{b}</span>
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="py-12 sm:py-20">
    <div class="container-wide">
      <div class="rounded-3xl bg-gradient-to-br from-brand-900 to-brand-700 p-10 text-center sm:p-16">
        <h2 class="font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">
          Not sure which fits?
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-brand-100">
          Send us the rough shape of the problem. We'll come back with a recommendation — even if it's "this is not the right scope for us."
        </p>
        <a href="/contact/" class="mt-8 inline-flex btn-primary !bg-white !text-brand-900 hover:!bg-brand-50">
          Talk to us →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
