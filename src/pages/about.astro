---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, ORG_DETAILS } from '../consts';

const stats = [
  { k: '15 years', v: 'Of building, advising, and supporting' },
  { k: '4+ apps', v: 'Live on the Atlassian Marketplace' },
  { k: '3 continents', v: 'BR, EU, and US East time zones' },
  { k: '4 practices', v: 'Software, Atlassian, consulting, support' },
];

const principles = [
  {
    title: 'Direct contact, no middle layer',
    body: 'The people you talk to are the people doing the work. No account managers translating between you and the team that ships.',
    icon: '🤝',
  },
  {
    title: 'Honest scope, honest no',
    body: 'We say so when something is the wrong shape, the wrong time, or the wrong fit, even when we could quote and bill for it.',
    icon: '🎯',
  },
  {
    title: 'Software and process together',
    body: 'A platform that nobody adopts is wasted. A process that nobody automates is slow. We treat them as one problem, not two.',
    icon: '🧩',
  },
  {
    title: 'Long view by default',
    body: 'Fifteen years of supporting what we shipped has taught us to build for year three, not just for launch day.',
    icon: '🌅',
  },
  {
    title: 'Atlassian fluent, not Atlassian only',
    body: 'When the answer is Atlassian we use it well. When it is not, we say so and reach for the right tool, even if that tool is not in the Marketplace.',
    icon: '🧭',
  },
];

const trustSignals = [
  { label: 'Atlassian Marketplace Partner', detail: 'Vendor 1064627585' },
  { label: 'Forge native', detail: 'Cloud first, no data egress' },
  { label: '4 published apps', detail: 'Jira, JSM, and Confluence' },
  { label: '15 years in the field', detail: 'Build, advise, run, support' },
];

const aboutPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  '@id': `${SITE.url}/about/#aboutpage`,
  url: `${SITE.url}/about/`,
  name: `About ${SITE.name}`,
  description: `${SITE.name} is a software house and consulting company. Fifteen years of building custom software, shipping Atlassian Forge apps for the Marketplace, advising on business and IT processes, and supporting the teams who run them.`,
  isPartOf: { '@id': `${SITE.url}/#website` },
  mainEntity: { '@id': `${SITE.url}/#organization` },
  inLanguage: 'en-US',
};
---

<BaseLayout
  title="About"
  description="Numeric Oasis is a software house and Atlassian Marketplace partner with 15 years of building custom software, Forge apps, and IT consulting. Based in Brazil, working across Brazil, Europe, and the US."
>
  <script type="application/ld+json" set:html={JSON.stringify(aboutPageJsonLd)} />

  <!-- HERO -->
  <section class="relative overflow-hidden bg-gradient-to-b from-sand-50 via-white to-white">
    <div class="absolute inset-0 -z-10 opacity-50" aria-hidden="true">
      <div class="absolute -left-32 top-0 h-[480px] w-[480px] rounded-full bg-water-300/40 blur-3xl"></div>
      <div class="absolute right-0 top-32 h-[420px] w-[420px] rounded-full bg-sun-300/30 blur-3xl"></div>
    </div>

    <div class="container-wide pt-20 pb-16 sm:pt-28 sm:pb-20">
      <p class="eyebrow">About Numeric Oasis</p>
      <h1 class="mt-4 max-w-4xl font-display text-4xl font-bold leading-[1.05] tracking-tight text-brand-900 sm:text-5xl md:text-6xl lg:text-7xl">
        A small studio with a long view,<br class="hidden md:block" />
        <span class="bg-gradient-to-r from-brand-700 via-water-500 to-sun-500 bg-clip-text text-transparent">and 15 years of work behind it.</span>
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-relaxed text-slate-600 sm:text-xl">
        Numeric Oasis is a software house and consulting company. We build custom SaaS and Atlassian Forge apps, we advise on business and IT processes, and we support the teams that run it all. Heavy on Atlassian and SaaS, with deep roots in business and IT service consulting.
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-3">
        <a href="/contact/" class="btn-cta">
          Talk to us about a project
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <a href="/services/" class="btn-secondary">See our services</a>
      </div>
    </div>
  </section>

  <!-- STATS STRIP -->
  <section class="border-y border-sand-200 bg-white">
    <div class="container-wide">
      <dl class="grid grid-cols-2 gap-8 py-10 sm:grid-cols-4 sm:py-12">
        {stats.map(({ k, v }) => (
          <div>
            <dt class="font-display text-3xl font-bold tracking-tight text-brand-900 sm:text-4xl">{k}</dt>
            <dd class="mt-2 text-sm leading-relaxed text-slate-600">{v}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- WHO WE ARE / WHAT WE DO -->
  <section class="py-16 sm:py-24">
    <div class="container-wide grid gap-12 md:grid-cols-2">
      <div>
        <p class="eyebrow">Who we are</p>
        <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-brand-900 sm:text-4xl">
          A software house and consulting company, since {ORG_DETAILS.foundingYear}.
        </h2>
        <div class="mt-6 space-y-5 text-base leading-relaxed text-slate-600">
          <p>
            We started in {ORG_DETAILS.foundingYear} doing IT service consulting and process implementation work. Over the years that practice grew alongside our software work: custom SaaS, web and mobile apps, integrations, and eventually Atlassian Forge apps that ship to the Marketplace.
          </p>
          <p>
            That history is why we resist drawing a hard line between "software" and "operations". Our customers rarely have just a software problem or just a process problem. They have both, and the answer is usually both.
          </p>
          <p>
            Today we are a small focused team operating across Brazilian, European, and US East time zones. Direct contact, written-first communication, and the same people from kickoff through long-term support.
          </p>
        </div>
      </div>

      <div>
        <p class="eyebrow">What we do</p>
        <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-brand-900 sm:text-4xl">
          Four practices, one team.
        </h2>
        <ul class="mt-6 space-y-4 text-base leading-relaxed text-slate-700">
          <li class="rounded-2xl border border-sand-200 bg-sand-50 p-5">
            <p class="font-semibold text-brand-900">Custom software & SaaS development</p>
            <p class="mt-1 text-sm text-slate-600">Greenfield SaaS, web and mobile apps, integrations, and bespoke platforms in TypeScript, Node, and React.</p>
          </li>
          <li class="rounded-2xl border border-sand-200 bg-sand-50 p-5">
            <p class="font-semibold text-brand-900">Atlassian apps & platform expertise</p>
            <p class="mt-1 text-sm text-slate-600">Forge apps for the Marketplace, custom plugins, migrations, audits, and Jira and Confluence health work.</p>
          </li>
          <li class="rounded-2xl border border-sand-200 bg-sand-50 p-5">
            <p class="font-semibold text-brand-900">Business & IT service consulting</p>
            <p class="mt-1 text-sm text-slate-600">ITIL, ITSM, process design, governance, and the rollouts that turn a strategy into an actually working operation.</p>
          </li>
          <li class="rounded-2xl border border-sand-200 bg-sand-50 p-5">
            <p class="font-semibold text-brand-900">Customer support & managed services</p>
            <p class="mt-1 text-sm text-slate-600">Long term support, SLAs, and operations for the software we build and the platforms you run on.</p>
          </li>
        </ul>
        <p class="mt-6 text-sm">
          <a href="/services/" class="font-semibold text-water-700 hover:text-water-600">Read more about each practice →</a>
        </p>
      </div>
    </div>
  </section>

  <!-- HOW WE WORK / PRINCIPLES -->
  <section class="bg-sand-50 py-16 sm:py-24">
    <div class="container-wide">
      <div class="max-w-3xl">
        <p class="eyebrow">How we work</p>
        <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-brand-900 sm:text-4xl">
          Five principles we keep coming back to.
        </h2>
        <p class="mt-4 text-base leading-relaxed text-slate-600">
          Fifteen years of customer relationships, postmortems, and good-and-bad decisions distilled into the small set of things we will not compromise on.
        </p>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {principles.map((p) => (
          <article class="rounded-2xl border border-sand-200 bg-white p-7 shadow-[var(--shadow-soft)]">
            <div class="text-3xl" aria-hidden="true">{p.icon}</div>
            <h3 class="mt-4 font-display text-lg font-semibold text-brand-900">{p.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600">{p.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- WHERE ATLASSIAN FITS -->
  <section class="py-16 sm:py-24">
    <div class="container-wide grid gap-12 md:grid-cols-3">
      <div class="md:col-span-1">
        <p class="eyebrow">Where Atlassian fits</p>
        <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-brand-900 sm:text-4xl">
          A specialty, not the whole identity.
        </h2>
      </div>
      <div class="md:col-span-2 space-y-5 text-base leading-relaxed text-slate-600">
        <p>
          Atlassian is one of our deepest specialties. We are an Atlassian Marketplace partner with apps already in production on Jira, Confluence, and Jira Service Management, all built on Atlassian Forge. We also do the platform work around them: Cloud migrations, audits, custom-field cleanups, performance work, and Marketplace strategy.
        </p>
        <p>
          And it is also, on purpose, not the whole story. When a customer's problem is best solved with Atlassian, we use it. When it is not, we say so and reach for the right tool. That includes greenfield SaaS, mobile apps, integrations with Slack, GitHub, AWS, Cloudflare, or whatever stack the customer already runs.
        </p>
        <p>
          <a href="/apps/" class="font-semibold text-water-700 hover:text-water-600">Browse our Marketplace apps →</a>
        </p>
      </div>
    </div>
  </section>

  <!-- TRUST SIGNALS -->
  <section class="border-y border-sand-200 bg-white py-12 sm:py-16">
    <div class="container-wide">
      <p class="eyebrow text-center">Credentials and standing</p>
      <ul class="mt-8 grid gap-6 text-center sm:grid-cols-2 lg:grid-cols-4">
        {trustSignals.map((t) => (
          <li class="flex flex-col items-center gap-2">
            <svg class="text-water-600" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            <p class="font-display text-sm font-semibold uppercase tracking-[0.14em] text-brand-800">{t.label}</p>
            <p class="text-xs leading-relaxed text-slate-500">{t.detail}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- WHY THE NAME -->
  <section class="py-16 sm:py-24">
    <div class="container-prose">
      <div class="prose-custom">
        <h2>Why "Numeric Oasis"</h2>
        <p>
          Because the work we love most lives at the intersection of clean numbers and breathing room. Data you can trust, and software that gives you space to think. The logo is a literal little oasis: a sun rising over teal and blue water, symbols for the technical work that gets done and the calm space we want our customers to feel while we do it.
        </p>
      </div>
    </div>
  </section>

  <!-- WHERE WE ARE -->
  <section class="bg-sand-50 py-16 sm:py-24">
    <div class="container-wide grid gap-10 md:grid-cols-2">
      <div>
        <p class="eyebrow">Where we are</p>
        <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-brand-900 sm:text-4xl">
          Headquartered in {SITE.location}.
        </h2>
      </div>
      <div class="space-y-4 text-base leading-relaxed text-slate-600">
        <p>
          We work across Brazilian, European, and US East time zones. Most of our calls are async. Most of our async is in writing. That gives our customers and our team predictable response windows without forcing anyone into bad-hour meetings.
        </p>
        <p>
          Reach us at <a class="font-semibold text-water-700 hover:text-water-600" href={`mailto:${SITE.email}`}>{SITE.email}</a> or through our <a class="font-semibold text-water-700 hover:text-water-600" href="/contact/">contact page</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 sm:py-24">
    <div class="container-wide">
      <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-brand-900 via-brand-800 to-deep-700 p-10 sm:p-16">
        <div class="absolute -right-20 -top-20 h-64 w-64 rounded-full bg-sun-500/30 blur-3xl" aria-hidden="true"></div>
        <div class="absolute -left-10 bottom-0 h-48 w-48 rounded-full bg-water-400/30 blur-3xl" aria-hidden="true"></div>
        <div class="relative max-w-2xl">
          <h2 class="font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">
            Have a project, a process, or a platform that needs work?
          </h2>
          <p class="mt-4 text-lg text-brand-100">
            Tell us the rough shape of the problem. We reply within one working day with an honest take and, if we are a fit, a path forward.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/contact/" class="btn-cta">
              Start the conversation
            </a>
            <a href="/services/" class="btn-secondary !bg-white">See what we do</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
